@using AirlineTicketingSystem.Models.Entities
@model CreateBookingVM

@{
    ViewData["Title"] = "Create Booking";
}

<h2>Create Booking</h2>
<hr />

@if (TempData["Info"] != null)
{
    <div class="alert alert-info">@TempData["Info"]</div>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form asp-action="Create" asp-controller="Booking" method="post" class="row g-3">
    @Html.AntiForgeryToken()

    <div class="col-md-6">
        <label asp-for="FlightId" class="form-label"></label>
        <select asp-for="FlightId" class="form-select" asp-items="Model.Flights" required>
            <option value="">-- Select Flight --</option>
        </select>
        <span asp-validation-for="FlightId" class="text-danger"></span>
    </div>

    <h4 class="mt-4">Passenger Details</h4>

    <div class="col-md-6">
        <label asp-for="Passenger.First_Name"></label>
        <input asp-for="Passenger.First_Name" class="form-control" />
        <span asp-validation-for="Passenger.First_Name" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Passenger.Last_Name"></label>
        <input asp-for="Passenger.Last_Name" class="form-control" />
        <span asp-validation-for="Passenger.Last_Name" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Passenger.PassportNumber"></label>
        <input asp-for="Passenger.PassportNumber" class="form-control" />
        <span asp-validation-for="Passenger.PassportNumber" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Passenger.Age"></label>
        <input asp-for="Passenger.Age" type="number" class="form-control" />
        <span asp-validation-for="Passenger.Age" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Passenger.ContactEmail"></label>
        <input asp-for="Passenger.ContactEmail" class="form-control" />
        <span asp-validation-for="Passenger.ContactEmail" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Passenger.PhoneNumber"></label>
        <input asp-for="Passenger.PhoneNumber" class="form-control" />
        <span asp-validation-for="Passenger.PhoneNumber" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="SeatClass" class="form-label"></label>
        <select asp-for="SeatClass" class="form-select"
                asp-items="Html.GetEnumSelectList<SeatClass>()" required></select>
        <span asp-validation-for="SeatClass" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="PassengerType" class="form-label"></label>
        <select asp-for="PassengerType" class="form-select"
                asp-items="Html.GetEnumSelectList<PassengerType>()" required></select>
        <span asp-validation-for="PassengerType" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="SeatCount" class="form-label"></label>
        <input asp-for="SeatCount" type="number" min="1" max="10" value="1" class="form-control" required />
        <span asp-validation-for="SeatCount"
              class="text-danger"></span>
    </div>

    <!-- Recommended: Do NOT allow customer to set IsPaid / BookingDate -->
    <!-- Controller sets BookingDate=DateTime.Now and IsPaid=false -->

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Create Booking</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
