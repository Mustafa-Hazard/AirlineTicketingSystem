@model AirlineTicketingSystem.Models.Entities.Booking

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Booking</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BookingReference)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.BookingReference)
        </dd>

        <dt class="col-sm-2">
            Flight
        </dt>
        <dd class="col-sm-10">
            @Model.Flight?.FlightNumber (@Model.Flight?.Origin → @Model.Flight?.Destination)
        </dd>

        <dt class="col-sm-2">
            Passenger
        </dt>
        <dd class="col-sm-10">
            @Model.Passenger?.FullName
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.SeatClass)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.SeatClass)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PassengerType)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PassengerType)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.SeatCount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.SeatCount)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TotalPrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TotalPrice)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsPaid)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsPaid)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
