@model AirlineTicketingSystem.Models.Entities.Booking
@{
    ViewData["Title"] = "Booking Details";
}
<h2>Booking Details</h2>
<div class="card p-3">
    <p><strong>Reference:</strong> @Model.BookingReference</p>
    <p><strong>Passenger:</strong> @Model.Passenger?.FullName</p>
    <p><strong>Flight:</strong> @Model.Flight?.FlightNumber (@Model.Flight?.Origin → @Model.Flight?.Destination)</p>
    <p><strong>Class:</strong> @Model.SeatClass</p>
    <p><strong>Type:</strong> @Model.PassengerType</p>
    <p><strong>Seats:</strong> @Model.SeatCount</p>
    <p><strong>Total Price:</strong> @Model.TotalPrice.ToString("C")</p>
    <p><strong>Paid:</strong> @(Model.IsPaid ? "Yes" : "No")</p>
    <a asp-action="Summary" asp-route-id="@Model.Id" class="btn btn-info">Summary</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>
