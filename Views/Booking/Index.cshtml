@model IEnumerable<AirlineTicketingSystem.Models.Entities.Booking>
@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-center">
    <h2>My Bookings</h2>

    @* Check if the user is a Customer to show New Booking button *@
    @if (User.Identity.IsAuthenticated && User.IsInRole("Customer"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> New Booking
        </a>
    }
</div>

<hr />

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Ref</th>
            <th>Flight</th>
            <th>Passenger</th>
            <th>Class</th>
            <th>Type</th>
            <th>Seats</th>
            <th>Total</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td><strong>@b.BookingReference</strong></td>
                <td>@b.Flight?.FlightNumber</td>
                <td>@b.Passenger?.FullName</td>
                <td>
                    <span class="badge bg-info text-dark">@b.SeatClass</span>
                </td>
                <td>@b.PassengerType</td>
                <td>@b.SeatCount</td>
                <td>@b.TotalPrice.ToString("C")</td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-info">Details</a>

                        @* Admin can Edit/Delete, Customer can only view details usually *@
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@b.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">No bookings found.</div>
}