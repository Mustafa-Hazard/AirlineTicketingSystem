@model IEnumerable<AirlineTicketingSystem.Models.Entities.Booking>
@{
    ViewData["Title"] = "Bookings";
}
<h2>Bookings</h2>
<p><a asp-action="Create" class="btn btn-primary">New Booking</a></p>
<table class="table table-striped">
    <thead>
        <tr><th>Ref</th><th>Flight</th><th>Passenger</th><th>Class</th><th>Type</th><th>Seats</th><th>Total</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.BookingReference</td>
                <td>@b.Flight?.FlightNumber</td>
                <td>@b.Passenger?.FullName</td>
                <td>@b.SeatClass</td>
                <td>@b.PassengerType</td>
                <td>@b.SeatCount</td>
                <td>@b.TotalPrice.ToString("C")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@b.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@b.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@b.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
