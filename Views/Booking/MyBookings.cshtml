@using AirlineTicketingSystem.Models.Entities
@model IEnumerable<Booking>
@{
    ViewData["Title"] = "My Bookings";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<h2>My Bookings</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Booking Ref</th>
            <th>Flight</th>
            <th>Route</th>
            <th>Departure</th>
            <th>Passenger</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.BookingReference</td>
                <td>@booking.Flight?.FlightNumber</td>
                <td>@booking.Flight?.Origin → @booking.Flight?.Destination</td>
                <td>@booking.Flight?.DepartureTime</td>
                <td>@booking.Passenger?.FullName</td>
                <td>$@booking.TotalPrice</td>

                <td>
                    @if (booking.IsPaid)
                    {
                        <span class="badge bg-success">Paid</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Unpaid</span>
                    }
                </td>

                <td>
                    <a asp-action="Summary" asp-route-id="@booking.Id"
                       class="btn btn-sm btn-info">View</a>

                    @* PAY OPTION *@
                    @if (!booking.IsPaid)
                    {
                        if (booking.Flight != null && booking.Flight.DepartureTime > DateTime.Now)
                        {
                            <button class="btn btn-sm btn-success"
                                    data-bs-toggle="modal"
                                    data-bs-target="#paymentModal"
                                    data-bookingid="@booking.Id">
                                Pay
                            </button>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Expired</span>
                        }
                    }

                    @* CANCEL/DELETE OPTION (Customer) *@
                    @if (booking.Flight != null && booking.Flight.DepartureTime > DateTime.Now)
                    {
                        <a asp-action="Cancel" asp-route-id="@booking.Id"
                           class="btn btn-sm btn-danger">
                            Cancel
                        </a>
                    }
                </td>

            </tr>
        }
    </tbody>
</table>

<div class="modal fade" id="paymentModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to confirm payment?
            </div>

            <div class="modal-footer">
                <form method="post" asp-action="PaymentSuccess">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookingId" id="bookingIdInput" />
                    <button type="submit" class="btn btn-success">
                        Confirm
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        var modal = document.getElementById('paymentModal');
        modal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var bookingId = button.getAttribute('data-bookingid');
            document.getElementById('bookingIdInput').value = bookingId;
        });
    </script>
}
