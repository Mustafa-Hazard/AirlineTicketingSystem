@model AirlineTicketingSystem.Models.ViewModels.BookingSummaryViewModel
@{
ViewData["Title"] = "Booking Summary";
}
<h2>Booking Summary</h2>
<div class="card p-3">
    <h4>Ref: @Model.BookingReference</h4>
    <p><strong>Passenger:</strong> @Model.PassengerName</p>
    <p><strong>Flight:</strong> @Model.FlightNumber</p>
    <p><strong>Route:</strong> @Model.From → @Model.To</p>
    <p><strong>Departure:</strong> @Model.DepartureTime.ToString("f")</p>
    <p><strong>Seat Class:</strong> @Model.SeatClass</p>
    <p><strong>Passenger Type:</strong> @Model.PassengerType</p>
    <p><strong>Seats:</strong> @Model.SeatCount</p>
    <p><strong>Price per seat:</strong> @Model.PricePerSeat.ToString("C")</p>
    <h4>Total: @Model.TotalPrice.ToString("C")</h4>
    <p><strong>Paid:</strong> @(Model.IsPaid ? "Yes" : "No")</p>
    <a asp-action="Index" class="btn btn-secondary">Back to Bookings</a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}