@model AirlineTicketingSystem.Models.ViewModels.CustomerDashboardVM

@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="mb-4">
        <h1 class="display-4">
            <i class="bi bi-person-circle"></i> Welcome back, @User.Identity.Name!
        </h1>
        <p class="text-muted">Here's an overview of your bookings and trips</p>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <!-- Total Bookings -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #4e73df !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small text-uppercase mb-1">Total Bookings</div>
                            <div class="h3 mb-0 font-weight-bold">@Model.TotalBookings</div>
                        </div>
                        <div>
                            <i class="bi bi-ticket-perforated-fill text-primary" style="font-size: 2.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upcoming Trips -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #1cc88a !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small text-uppercase mb-1">Upcoming Trips</div>
                            <div class="h3 mb-0 font-weight-bold">@Model.UpcomingTrips</div>
                        </div>
                        <div>
                            <i class="bi bi-airplane-fill text-success" style="font-size: 2.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Spent -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #36b9cc !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small text-uppercase mb-1">Total Spent</div>
                            <div class="h3 mb-0 font-weight-bold">@Model.TotalSpent.ToString("C")</div>
                        </div>
                        <div>
                            <i class="bi bi-cash-coin text-info" style="font-size: 2.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- My Passengers -->
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #f6c23e !important;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small text-uppercase mb-1">My Passengers</div>
                            <div class="h3 mb-0 font-weight-bold">@Model.TotalPassengers</div>
                        </div>
                        <div>
                            <i class="bi bi-people-fill text-warning" style="font-size: 2.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Payments Alert -->
    @if (Model.PendingPayments > 0)
    {
        <div class="alert alert-warning border-0 shadow-sm mb-4">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 2rem;"></i>
                <div>
                    <h5 class="alert-heading mb-1">Pending Payments</h5>
                    <p class="mb-0">
                        You have <strong>@Model.PendingPayments.ToString("C")</strong> in unpaid bookings.
                        <a asp-controller="Booking" asp-action="Index" class="alert-link">View bookings</a>
                    </p>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <!-- Upcoming Trips -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-calendar-event"></i> Upcoming Trips</h5>
                    <a asp-controller="Booking" asp-action="Index" class="btn btn-sm btn-light">View All</a>
                </div>
                <div class="card-body p-0">
                    @if (Model.UpcomingBookings.Count > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var booking in Model.UpcomingBookings)
                            {
                                <div class="list-group-item">
                                    <div class="row align-items-center">
                                        <div class="col-md-2 text-center">
                                            <div class="bg-primary text-white rounded p-2">
                                                <div class="h4 mb-0">@booking.Flight.DepartureTime.ToString("dd")</div>
                                                <small>@booking.Flight.DepartureTime.ToString("MMM")</small>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <h6 class="mb-1">
                                                <strong>@booking.Flight.FlightNumber</strong>
                                                @if (booking.Flight.IsDelayed)
                                                {
                                                    <span class="badge bg-danger">Delayed</span>
                                                }
                                            </h6>
                                            <p class="mb-1">
                                                <i class="bi bi-geo-alt-fill text-primary"></i>
                                                <strong>@booking.Flight.Origin</strong>
                                                <i class="bi bi-arrow-right mx-2"></i>
                                                <strong>@booking.Flight.Destination</strong>
                                            </p>
                                            <small class="text-muted">
                                                <i class="bi bi-clock"></i>
                                                @booking.Flight.DepartureTime.ToString("hh:mm tt")
                                            </small>
                                        </div>
                                        <div class="col-md-4 text-end">
                                            <div class="mb-2">
                                                <span class="badge bg-info">@booking.SeatClass</span>
                                                <span class="badge bg-secondary">@booking.SeatCount seat(s)</span>
                                            </div>
                                            @if (booking.IsPaid)
                                            {
                                                <span class="badge bg-success mb-2">Paid</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning mb-2">Unpaid</span>
                                            }
                                            <div>
                                                <a asp-controller="Booking" asp-action="Summary" asp-route-id="@booking.Id"
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye"></i> View Details
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center">
                            <i class="bi bi-airplane text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3">No upcoming trips scheduled.</p>
                            <a asp-controller="Flights" asp-action="Search" class="btn btn-primary">
                                <i class="bi bi-search"></i> Search Flights
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Quick Actions & Passengers -->
        <div class="col-lg-4 mb-4">
            <!-- Quick Actions -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-lightning-fill"></i> Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-controller="Flights" asp-action="Search" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search Flights
                        </a>
                        <a asp-controller="Booking" asp-action="Create" class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> New Booking
                        </a>
                        <a asp-controller="Passenger" asp-action="Create" class="btn btn-info">
                            <i class="bi bi-person-plus"></i> Add Passenger
                        </a>
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-list-ul"></i> My Bookings
                        </a>
                    </div>
                </div>
            </div>

            <!-- My Passengers -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-white">
                    <h5 class="mb-0"><i class="bi bi-people"></i> My Passengers</h5>
                </div>
                <div class="card-body">
                    @if (Model.MyPassengers.Count > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var passenger in Model.MyPassengers)
                            {
                                <div class="list-group-item px-0">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0">@passenger.FullName</h6>
                                            <small class="text-muted">@passenger.PassportNumber</small>
                                        </div>
                                        <a asp-controller="Passenger" asp-action="Details" asp-route-id="@passenger.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-2">No passengers added yet.</p>
                        <a asp-controller="Passenger" asp-action="Create" class="btn btn-sm btn-primary">
                            <i class="bi bi-person-plus"></i> Add Passenger
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Bookings -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Bookings</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.RecentBookings.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Booking Ref</th>
                                <th>Flight</th>
                                <th>Route</th>
                                <th>Departure</th>
                                <th>Passenger</th>
                                <th>Class</th>
                                <th>Status</th>
                                <th>Amount</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in Model.RecentBookings)
                            {
                                <tr>
                                    <td><strong>@booking.BookingReference</strong></td>
                                    <td>@booking.Flight.FlightNumber</td>
                                    <td>
                                        <small>@booking.Flight.Origin → @booking.Flight.Destination</small>
                                    </td>
                                    <td>
                                        <small>@booking.Flight.DepartureTime.ToString("MMM dd, HH:mm")</small>
                                    </td>
                                    <td>@booking.Passenger.FullName</td>
                                    <td><span class="badge bg-secondary">@booking.SeatClass</span></td>
                                    <td>
                                        @if (booking.IsPaid)
                                        {
                                            <span class="badge bg-success">Paid</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Unpaid</span>
                                        }
                                    </td>
                                    <td><strong class="text-success">@booking.TotalPrice.ToString("C")</strong></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-controller="Booking" asp-action="Summary" asp-route-id="@booking.Id"
                                               class="btn btn-outline-primary" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-controller="Booking" asp-action="ETicket" asp-route-id="@booking.Id"
                                               class="btn btn-outline-success" title="Download Ticket">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-center">
                    <p class="text-muted mb-0">No bookings yet. Start your journey today!</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-3px);
        }
</style>