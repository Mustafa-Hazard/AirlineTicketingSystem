@{
    ViewData["Title"] = "Mark Flight as Delayed";
}

<h2>Mark Flight as Delayed</h2>
<hr />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<form method="post" asp-action="Delay" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">New Departure Time</label>
        <input type="datetime-local" class="form-control" name="newDepartureTime" required />
    </div>

    <button type="submit" class="btn btn-primary">Update Delay</button>
</form>

<div>
    <a class="btn btn-secondary mt-3" asp-action="Index">Back to Flight List</a>
</div>
