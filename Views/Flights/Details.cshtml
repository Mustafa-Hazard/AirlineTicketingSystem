@model AirlineTicketingSystem.Models.Entities.Flight

@{
    ViewData["Title"] = "Flight Details";
}

<h2>Flight Details</h2>

<div class="card p-3">
    <h4>@Model.FlightNumber — @Model.Origin → @Model.Destination</h4>
    <p><strong>Departure:</strong> @Model.DepartureTime.ToString("f")</p>

    <p>
        <strong>Status:</strong>
        @if (Model.IsDelayed)
        {
            <span class="badge bg-danger">Delayed</span>
        }
        else
        {
            <span class="badge bg-success">On Time</span>
        }
    </p>

    <p><strong>Arrival:</strong> @Model.ArrivalTime.ToString("f")</p>
    <p><strong>Duration:</strong> @Model.Duration</p>

    <p><strong>Economy:</strong> @Model.EconomySeats total / @Model.AvailableEconomySeats available (@Model.EconomyPrice)</p>
    <p><strong>Business:</strong> @Model.BusinessSeats total / @Model.AvailableBusinessSeats available (@Model.BusinessPrice)</p>
    <p><strong>First Class:</strong> @Model.FirstClassSeats total / @Model.AvailableFirstClassSeats available (@Model.FirstClassPrice)</p>

    <div class="mt-3">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>
