@model IEnumerable<AirlineTicketingSystem.Models.Entities.Flight>
@{
    ViewData["Title"] = "Flights";
}
<h2>Flights</h2>
<p><a asp-action="Create" class="btn btn-primary">Add Flight</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Flight</th>
            <th>Route</th>
            <th>Departure</th>
            <th>Arrival</th>
            <th>Economy / Avail</th>
            <th>Business / Avail</th>
            <th>First / Avail</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var f in Model)
        {
            <tr>
                <td>@f.FlightNumber</td>
                <td>@f.Origin → @f.Destination</td>
                <td>@f.DepartureTime.ToString("g")</td>
                <td>@f.ArrivalTime.ToString("g")</td>
                <td>@f.EconomySeats / @f.AvailableEconomySeats</td>
                <td>@f.BusinessSeats / @f.AvailableBusinessSeats</td>
                <td>@f.FirstClassSeats / @f.AvailableFirstClassSeats</td>
                <td>

                    <a asp-action="Details" asp-route-id="@f.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@f.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@f.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
