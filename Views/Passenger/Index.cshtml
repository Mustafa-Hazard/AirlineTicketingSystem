@model IEnumerable<AirlineTicketingSystem.Models.Entities.Passenger>
@{
    ViewData["Title"] = "Passengers";
}
<h2>Passengers</h2>
<p><a asp-action="Create" class="btn btn-primary">Add Passenger</a></p>

<table class="table table-striped">
    <thead><tr><th>Name</th><th>Passport</th><th>Email</th><th>Phone</th><th>Age</th><th>Nationality</th></tr></thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.FullName</td>
                <td>@p.PassportNumber</td>
                <td>@p.ContactEmail</td>
                <td>@p.PhoneNumber</td>
                <td>@p.Age</td>
                <td>@p.Nationality</td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@p.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@p.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
