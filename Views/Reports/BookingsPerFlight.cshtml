@model IEnumerable<AirlineTicketingSystem.Models.ViewModels.FlightReportRowVM>

@{
    ViewData["Title"] = "Bookings per Flight";
}

<h2>Bookings per Flight</h2>
<hr />

<form method="get">
    <div class="row mb-3">
        <div class="col-md-4">
            <label for="startDate">Start Date</label>
            <input type="date" id="startDate" name="startDate" class="form-control" />
        </div>
        <div class="col-md-4">
            <label for="endDate">End Date</label>
            <input type="date" id="endDate" name="endDate" class="form-control" />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary mt-4">Filter</button>
        </div>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Flight #</th>
            <th>Route</th>
            <th>Departure</th>
            <th>Bookings</th>
            <th>Seats Booked</th>
            <th>Paid Revenue</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Model)
        {
            <tr>
                <td>@row.FlightNumber</td>
                <td>@row.Origin → @row.Destination</td>
                <td>@row.DepartureTime.ToString("dd MMM yyyy, HH:mm")</td>
                <td>@row.BookingCount</td>
                <td>@row.SeatsBooked</td>
                <td>@row.PaidRevenue.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>
