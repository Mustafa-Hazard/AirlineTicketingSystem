<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AeroNexa</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/bootswatch-css/bootstrap.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body.dark-mode {
            background-color: #121212;
            color: #e8e8e8;
        }

        .dark-mode .navbar {
            background-color: #222 !important;
        }

        #toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1055;
        }

        .search-form input[type="text"] {
            border: 1px solid #ccc;
            border-radius: .25rem 0 0 .25rem;
            padding: .375rem .75rem;
        }

        .search-form button {
            border-radius: 0 .25rem .25rem 0;
            border: 1px solid #ccc;
            border-left: 0;
            padding: .375rem .75rem;
            background-color: #fff;
        }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-primary" data-bs-theme="dark">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-airplane-fill me-1"></i> AeroNexa
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarColor01" aria-controls="navbarColor01"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarColor01">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                        }

                        <!-- Flights Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">
                                <i class="bi bi-airplane"></i> Flights
                            </a>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" asp-action="Index" asp-controller="Flights">View All</a>
                                <a class="dropdown-item" asp-action="Search" asp-controller="Flights">Search Flights</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" asp-action="Create" asp-controller="Flights">Create Flight</a>
                                    <a class="dropdown-item" asp-controller="Flights" asp-action="ViewAllWithBookings">Flights with Bookings</a>
                                }
                            </div>
                        </li>

                        <!-- Bookings Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">
                                <i class="bi bi-journal-bookmark-fill"></i> Bookings
                            </a>
                            <div class="dropdown-menu">
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <a class="dropdown-item" asp-controller="Booking" asp-action="Create">Create Booking</a>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <a class="dropdown-item" asp-controller="Booking" asp-action="Index">View All Bookings</a>
                                }
                            </div>
                        </li>

                        <!-- Passengers Dropdown (Admin Only) -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">
                                    <i class="bi bi-people-fill"></i> Passengers
                                </a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" asp-action="Index" asp-controller="Passenger">View All</a>
                                    <a class="dropdown-item" asp-action="Create" asp-controller="Passenger">Create</a>
                                </div>
                            </li>
                        }

                        <!-- Reports Dropdown (Admin Only) -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">
                                    <i class="bi bi-graph-up-arrow"></i> Reports
                                </a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" asp-controller="Reports" asp-action="BookingsPerFlight">Bookings per Flight</a>
                                    <a class="dropdown-item" asp-controller="Reports" asp-action="Revenue">Revenue Statistics</a>
                                </div>
                            </li>
                        }
                    </ul>

                    <!-- Search Form -->
                    <form class="d-flex me-3" method="get" asp-controller="Flights" asp-action="Search">
                        <input class="form-control me-sm-2" type="search" name="Origin" placeholder="Search flights...">
                        <button class="btn btn-secondary my-2 my-sm-0" type="submit">Search</button>
                    </form>

                    <!-- Auth Links -->
                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <div class="dropdown-menu dropdown-menu-end">
                                    <div class="dropdown-header">
                                        Role: <strong>@(User.IsInRole("Admin") ? "Admin" : "Customer")</strong>
                                    </div>
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" asp-controller="Auth" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </div>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Register">
                                    <i class="bi bi-person-plus"></i> Register
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Dark Mode Toggle -->
                    <button class="btn btn-outline-light ms-2" id="toggleTheme">
                        <i class="bi bi-moon-stars" id="themeIcon"></i>
                    </button>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        @if (ViewData["Breadcrumb"] != null)
        {
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    @foreach (var item in (List<string>)ViewData["Breadcrumb"])
                    {
                        <li class="breadcrumb-item">@item</li>
                    }
                </ol>
            </nav>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; <span id="year"></span> - AeroNexa -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <div id="toast-container"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.getElementById("year").textContent = new Date().getFullYear();

        const toggleBtn = document.getElementById('toggleTheme');
        const icon = document.getElementById('themeIcon');

        toggleBtn.addEventListener('click', () => {
            document.body.classList.toggle('dark-mode');
            icon.classList.toggle('bi-moon-stars');
            icon.classList.toggle('bi-sun-fill');
        });

        function showToast(message, type = "success") {
            const toast = document.createElement("div");
            toast.className = `alert alert-${type} fade show`;
            toast.innerHTML = message;
            document.getElementById("toast-container").appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>